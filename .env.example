# ── Privacy Sharing Matrix ─────────────────────────────────────────────────
# Controls what data types are shared with each destination.
# PRIVACY_MODE selects a preset: off | standard | strict | paranoid | custom
# Individual cells can be overridden with PRIVACY_<DATA>_<DEST>=<level>
# Data types: AUDIO, OCR, IMAGES, TITLES, CREDENTIALS, METADATA
# Destinations: LOCAL_BUFFER, LOCAL_LLM, TRIPLE_STORE, OPENROUTER, AGENT_GATEWAY
# Levels: full | redacted | summary | none
PRIVACY_MODE=off
# Example overrides (uncomment to activate):
# PRIVACY_IMAGES_OPENROUTER=none
# PRIVACY_OCR_OPENROUTER=redacted
# PRIVACY_AUDIO_AGENT_GATEWAY=summary
# PRIVACY_TITLES_OPENROUTER=none

# SinainHUD Bridge Configuration
OPENCLAW_GATEWAY_URL=http://localhost:3000
OPENCLAW_TOKEN=your-gateway-token-here
OPENCLAW_SESSION_KEY=your-session-key-here
WS_PORT=9500
RELAY_MIN_INTERVAL_MS=30000

# SITUATION.md + OpenClaw Escalation
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
SITUATION_MD_ENABLED=true
OPENCLAW_GATEWAY_WS_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-auth-token-here
OPENCLAW_HOOK_URL=http://localhost:18789/hooks/agent
OPENCLAW_HOOK_TOKEN=your-hook-token-here
ESCALATION_MODE=selective
ESCALATION_COOLDOWN_MS=30000
